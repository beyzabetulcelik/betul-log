const jsonHeaders = {
  'Content-Type': 'application/json; charset=utf-8',
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'Authorization, Content-Type',
  'Access-Control-Allow-Methods': 'POST, OPTIONS'
};

function response(body, status = 200) {
  return new Response(JSON.stringify(body), { status, headers: jsonHeaders });
}

function toBase64Utf8(value) {
  const bytes = new TextEncoder().encode(value);
  let binary = '';
  for (const byte of bytes) binary += String.fromCharCode(byte);
  return btoa(binary);
}

function fromBase64Utf8(value) {
  const binary = atob(value.replace(/\n/g, ''));
  const bytes = Uint8Array.from(binary, char => char.charCodeAt(0));
  return new TextDecoder().decode(bytes);
}

function slugify(value) {
  return value
    .toLowerCase()
    .normalize('NFKD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
    .slice(0, 48) || 'moment';
}

async function githubRequest(env, path, options = {}) {
  const url = `https://api.github.com/repos/${env.GITHUB_OWNER}/${env.GITHUB_REPO}/contents/${path}`;
  return fetch(url, {
    ...options,
    headers: {
      'Accept': 'application/vnd.github+json',
      'Authorization': `Bearer ${env.GITHUB_TOKEN}`,
      'User-Agent': 'betul-log-worker',
      'X-GitHub-Api-Version': '2022-11-28',
      ...(options.headers || {})
    }
  });
}

async function putFile(env, path, contentBase64, message, sha) {
  const body = { message, content: contentBase64, branch: env.GITHUB_BRANCH || 'main' };
  if (sha) body.sha = sha;
  const result = await githubRequest(env, path, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  if (!result.ok) throw new Error(`GitHub write failed: ${await result.text()}`);
  return result.json();
}

export default {
  async fetch(request, env) {
    if (request.method === 'OPTIONS') return new Response(null, { headers: jsonHeaders });
    if (request.method !== 'POST') return response({ error: 'POST only.' }, 405);

    const auth = request.headers.get('Authorization');
    if (auth !== `Bearer ${env.POSTING_SECRET}`) return response({ error: 'Unauthorized.' }, 401);

    try {
      const body = await request.json();
      if (!body.text || typeof body.text !== 'string') return response({ error: 'Text is required.' }, 400);
      if (body.text.length > 5000) return response({ error: 'Entry is too long.' }, 400);

      const now = body.date ? new Date(body.date) : new Date();
      if (Number.isNaN(now.getTime())) return response({ error: 'Invalid date.' }, 400);

      const id = `${now.toISOString().slice(0, 10)}-${slugify(body.title || body.text.slice(0, 40))}-${crypto.randomUUID().slice(0, 8)}`;
      let imagePath = '';

      if (body.image_data_url) {
        const match = body.image_data_url.match(/^data:(image\/(jpeg|png|webp|heic));base64,(.+)$/);
        if (!match) return response({ error: 'Unsupported image format.' }, 400);
        const extension = match[2] === 'jpeg' ? 'jpg' : match[2];
        imagePath = `images/${id}.${extension}`;
        await putFile(env, `site/${imagePath}`, match[3], `Add image for ${id}`);
      }

      const postsResponse = await githubRequest(env, 'site/posts.json?ref=' + encodeURIComponent(env.GITHUB_BRANCH || 'main'));
      if (!postsResponse.ok) throw new Error(`Could not read posts.json: ${await postsResponse.text()}`);
      const postsFile = await postsResponse.json();
      const posts = JSON.parse(fromBase64Utf8(postsFile.content));

      posts.unshift({
        id,
        date: now.toISOString(),
        title: String(body.title || '').trim(),
        text: body.text.trim(),
        location: String(body.location || '').trim(),
        mood: String(body.mood || '').trim(),
        image: imagePath
      });

      await putFile(
        env,
        'site/posts.json',
        toBase64Utf8(JSON.stringify(posts, null, 2) + '\n'),
        `Add log entry ${id}`,
        postsFile.sha
      );

      return response({ ok: true, id });
    } catch (error) {
      return response({ error: error.message || 'Unexpected error.' }, 500);
    }
  }
};
