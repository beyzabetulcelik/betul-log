<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#f4f1ea" />
  <title>New entry · Logbook</title>
  <link rel="manifest" href="manifest.webmanifest" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body class="capture-page">
  <main class="capture-shell">
    <a class="back-link" href="index.html">← Logbook</a>
    <h1>New entry</h1>
    <p class="subtitle">Keep it small. One moment is enough.</p>

    <form id="entry-form" class="entry-form">
      <label>
        Photo <span>(optional)</span>
        <input id="photo" type="file" accept="image/*" capture="environment" />
      </label>

      <label>
        What happened?
        <textarea id="text" rows="5" required placeholder="One sentence is enough."></textarea>
      </label>

      <label>
        Title <span>(optional)</span>
        <input id="title" type="text" placeholder="Soundscape" />
      </label>

      <div class="two-column">
        <label>
          Place <span>(optional)</span>
          <input id="location" type="text" placeholder="Istanbul" />
        </label>
        <label>
          Mood <span>(optional)</span>
          <input id="mood" type="text" placeholder="Alive" />
        </label>
      </div>

      <label>
        Private posting key
        <input id="secret" type="password" required autocomplete="current-password" placeholder="Saved only on this phone" />
      </label>

      <button id="submit-button" type="submit">Save moment</button>
      <p id="status" class="status" role="status"></p>
    </form>
  </main>

  <script src="config.js"></script>
  <script src="new.js" defer></script>
</body>
</html>
